# FoodLens configuration — copy to .env and adjust.
# LLM provider: template (default, zero deps) | local (flan-t5-base) | anthropic
LLM_PROVIDER=template
# Only needed when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Device override: auto | cpu | cuda
DEVICE=auto
# DataLoader workers (Windows: keep 0)
NUM_WORKERS=0
# Database URL
DATABASE_URL=sqlite:///foodlens.db
